  "chapters": {
    "ch1": {
      "id": "ch1",
      "number": "1",
      "title": "Introduction",
      "blocks": [
        {
          "id": "b1_intro",
          "label": "Request for Quotation",
          "defaultOn": true,
          "text": "{{companyName}} (hereafter: STM) requests {{supplierName}} (hereafter: Supplier) to submit a binding quotation for interior wall and ceiling finishing for the project:\n\n{{projectName}}\nProject number: {{projectNumber}}\nSite address: {{siteAddress}}, {{siteZip}} {{siteCity}}\n\nSTM contact: {{stmContact}}\nSupplier contact: {{supplierContact}}\n\nThe quotation shall be explicitly and exclusively based on the project documentation provided by STM, consisting of:\n- the IFC model (if provided);\n- the accompanying 2D drawings (PDF and/or DWG);\n- this Request for Quotation document.\n\nThe Supplier shall not deviate from the specifications set out in this document without prior written approval from STM. Any deviation, assumption, or exclusion not explicitly stated in the Supplier's quotation shall be deemed accepted as specified herein.\n\nThe scope encompasses all materials, provisions, and logistics necessary for a complete and functional delivery. Items not explicitly excluded under Chapter 6 are deemed included.\n\nSTM reserves the right to award part of the scope to alternative suppliers.",
          "variables": [
            {
              "id": "companyName",
              "label": "STM Entity",
              "type": "select",
              "options": [
                "Staalmeesters Projects BV",
                "STM Design & Build BV",
                "STM Design & Build GmbH"
              ],
              "default": "Staalmeesters Projects BV",
              "source": "specs"
            },
            {
              "id": "supplierName",
              "label": "Supplier name",
              "type": "text",
              "source": "specs"
            },
            {
              "id": "projectName",
              "label": "Project name",
              "type": "text",
              "source": "specs"
            },
            {
              "id": "projectNumber",
              "label": "Project number",
              "type": "text",
              "source": "specs"
            },
            {
              "id": "siteAddress",
              "label": "Site address",
              "type": "text",
              "source": "specs"
            },
            {
              "id": "siteZip",
              "label": "Postal code",
              "type": "text",
              "source": "specs"
            },
            {
              "id": "siteCity",
              "label": "Site city",
              "type": "text",
              "source": "specs"
            },
            {
              "id": "stmContact",
              "label": "STM contact",
              "type": "text",
              "source": "specs"
            },
            {
              "id": "supplierContact",
              "label": "Supplier contact",
              "type": "text",
              "source": "specs"
            }
          ]
        }
      ]
    },
    "ch2": {
      "id": "ch2",
      "number": "2",
      "title": "Scope of Supply",
      "blocks": [
        {
          "id": "b2_wall",
          "label": "Metal Stud Walls",
          "defaultOn": true,
          "text": "Interior partitions:\n\nType: {{wallType}}\nPlasterboard: {{pbType}}\nHeight: {{wallH}} m\nArea: {{wallA}} m²\nAcoustic: min {{acoustic}} dB\nFire: {{wallFire}}\nFinish: {{wallFin}}\n\nIncludes: studs, insulation, plasterboard both sides, jointing, finishing.",
          "variables": [
            {
              "id": "wallType",
              "label": "Wall type",
              "type": "select",
              "options": [
                "Single 75mm",
                "Single 100mm",
                "Double frame",
                "Shaft wall"
              ],
              "default": "Single 100mm",
              "source": "specs"
            },
            {
              "id": "pbType",
              "label": "Plasterboard",
              "type": "select",
              "options": [
                "Standard (A)",
                "Moisture (H)",
                "Fire (F)",
                "Impact (I)"
              ],
              "default": "Standard (A)",
              "source": "specs"
            },
            {
              "id": "wallH",
              "label": "Height (m)",
              "type": "number",
              "source": "specs"
            },
            {
              "id": "wallA",
              "label": "Area (m²)",
              "type": "number",
              "source": "specs"
            },
            {
              "id": "acoustic",
              "label": "Acoustic (dB)",
              "type": "number",
              "default": "42",
              "source": "specs"
            },
            {
              "id": "wallFire",
              "label": "Fire",
              "type": "select",
              "options": [
                "None",
                "EI 30",
                "EI 60",
                "EI 90"
              ],
              "default": "EI 30",
              "source": "specs"
            },
            {
              "id": "wallFin",
              "label": "Finish",
              "type": "select",
              "options": [
                "Level 2 (paint ready)",
                "Level 3 (std paint)",
                "Level 4 (high quality)"
              ],
              "default": "Level 3 (std paint)",
              "source": "specs"
            }
          ]
        },
        {
          "id": "b2_ceil",
          "label": "Suspended Ceilings",
          "defaultOn": false,
          "text": "Suspended ceilings:\n\nType: {{ceilType}}\nPanel: {{ceilPan}}\nGrid: {{ceilGrid}}\nHeight: {{ceilH}} m\nArea: {{ceilA}} m²\n\nIncludes: grid, tiles, perimeter, services integration.",
          "variables": [
            {
              "id": "ceilType",
              "label": "Type",
              "type": "select",
              "options": [
                "Lay-in tile",
                "Clip-in metal",
                "Plasterboard",
                "Acoustic baffles"
              ],
              "default": "Lay-in tile",
              "source": "specs"
            },
            {
              "id": "ceilPan",
              "label": "Panel",
              "type": "text",
              "default": "600×600 mineral fibre",
              "source": "specs"
            },
            {
              "id": "ceilGrid",
              "label": "Grid",
              "type": "select",
              "options": [
                "Exposed T-bar",
                "Concealed",
                "Custom"
              ],
              "default": "Exposed T-bar",
              "source": "specs"
            },
            {
              "id": "ceilH",
              "label": "Height (m)",
              "type": "number",
              "default": "2.80",
              "source": "specs"
            },
            {
              "id": "ceilA",
              "label": "Area (m²)",
              "type": "number",
              "source": "specs"
            }
          ]
        },
        {
          "id": "b2_intd",
          "label": "Interior Doors",
          "defaultOn": false,
          "text": "Interior doors:\n\nType: {{dType}}, {{dW}}×{{dH}} mm, qty: {{dQty}}\nFire: {{dFire}}\nHardware: {{dHW}}\n\nIncludes: leaf, frame, hardware, install.",
          "variables": [
            {
              "id": "dType",
              "label": "Type",
              "type": "select",
              "options": [
                "Flush panel",
                "Glazed",
                "Steel"
              ],
              "default": "Flush panel",
              "source": "specs"
            },
            {
              "id": "dW",
              "label": "Width (mm)",
              "type": "number",
              "default": "930",
              "source": "specs"
            },
            {
              "id": "dH",
              "label": "Height (mm)",
              "type": "number",
              "default": "2115",
              "source": "specs"
            },
            {
              "id": "dQty",
              "label": "Qty",
              "type": "number",
              "source": "specs"
            },
            {
              "id": "dFire",
              "label": "Fire",
              "type": "select",
              "options": [
                "None",
                "EI 30",
                "EI 60"
              ],
              "default": "None",
              "source": "specs"
            },
            {
              "id": "dHW",
              "label": "Hardware",
              "type": "select",
              "options": [
                "Standard",
                "Office set",
                "Fire-rated set"
              ],
              "default": "Standard",
              "source": "specs"
            }
          ]
        }
      ]
    },
    "ch3": {
      "id": "ch3",
      "number": "3",
      "title": "Standards",
      "blocks": [
        {
          "id": "b3_std",
          "label": "Standards",
          "defaultOn": true,
          "text": "EN 520, EN 13964, EN 14195, NEN 5077, EN 13501-2, Bouwbesluit.\nAttach: system certs, acoustic reports, fire reports.",
          "variables": []
        }
      ]
    },
    "ch4": {
      "id": "ch4",
      "number": "4",
      "title": "Delivery & Execution",
      "blocks": [
        {
          "id": "b4_del",
          "label": "Execution Terms",
          "defaultOn": true,
          "text": "Site: {{siteAddress}}, {{siteZip}} {{siteCity}}.\n\nWorking hours: {{workingHours}}\nEstimated duration: {{duration}}\nStart date: {{startDate}}\n\nThe Supplier shall:\n- Mobilise within {{mobiliseDays}} working days after instruction\n- Coordinate with STM site manager\n- Maintain site cleanliness\n- Reinstate any damage caused by Supplier's operations\n\nQuantities indicative. STM may adjust +/- {{quantityTolerance}}% without price change per unit rate.",
          "variables": [
            {
              "id": "siteAddress",
              "label": "Site address",
              "type": "text",
              "source": "specs"
            },
            {
              "id": "siteZip",
              "label": "Postal code",
              "type": "text",
              "source": "specs"
            },
            {
              "id": "siteCity",
              "label": "Site city",
              "type": "text",
              "source": "specs"
            },
            {
              "id": "workingHours",
              "label": "Working hours",
              "type": "text",
              "default": "07:00–17:00, Mon–Fri",
              "source": "specs"
            },
            {
              "id": "duration",
              "label": "Duration",
              "type": "text",
              "delegateText": "State estimated duration and resource availability.",
              "source": "specs"
            },
            {
              "id": "startDate",
              "label": "Start date",
              "type": "text",
              "delegateText": "State earliest available start date.",
              "source": "specs"
            },
            {
              "id": "mobiliseDays",
              "label": "Mobilise (d)",
              "type": "number",
              "default": "5",
              "source": "specs"
            },
            {
              "id": "quantityTolerance",
              "label": "Qty tolerance (%)",
              "type": "number",
              "default": "15",
              "source": "specs"
            }
          ]
        }
      ]
    },
    "ch5": {
      "id": "ch5",
      "number": "5",
      "title": "Pricing & Surcharges",
      "blocks": [
        {
          "id": "b5_pr",
          "label": "Price Structure",
          "defaultOn": true,
          "text": "Complete price breakdown required:\n\nPer m² stud wall (per type)\nPer m² suspended ceiling\nPer piece interior door\nPer m1 skirting\n\nSurcharges: above-std height, curved walls, complex details.\n\nValidity: minimum {{validityDays}} days.\nState if prices subject to material index.\n\nPayment: {{paymentDays}} days after invoice.\n\nSurcharges not stated are deemed included and cannot be invoiced separately.",
          "variables": [
            {
              "id": "validityDays",
              "label": "Validity (d)",
              "type": "number",
              "default": "30",
              "source": "specs"
            },
            {
              "id": "paymentDays",
              "label": "Payment (d)",
              "type": "number",
              "default": "30",
              "source": "specs"
            }
          ]
        }
      ]
    },
    "ch6": {
      "id": "ch6",
      "number": "6",
      "title": "Exclusions",
      "blocks": [
        {
          "id": "b6_ex",
          "label": "Scope Exclusions",
          "defaultOn": true,
          "text": "Excluded (procured separately by STM):\n\n- Structural works\n- M&E first fix\n- Floor finishing\n- Painting (if separate)\n- Furniture\n- VAT\n\nSupplier shall state additional exclusions. Items not listed and not excluded by Supplier are deemed included.\n\nInstallation instructions and documentation provided at no additional cost.",
          "variables": []
        }
      ]
    },
    "ch7": {
      "id": "ch7",
      "number": "7",
      "title": "Quotation Requirements",
      "blocks": [
        {
          "id": "b7_sub",
          "label": "Submission",
          "defaultOn": true,
          "text": "Submit to {{stmContact}} at {{stmEmail}} before {{deadline}}.\n\nInclude:\n1. Price schedule\n2. System specs\n3. Acoustic reports\n4. Fire reports\n5. Material data\n6. Duration\n7. General terms\n8. Deviations\n\nIncomplete quotations may be rejected.\nSTM is not obligated to award to lowest bidder.\nThis RFQ does not constitute a commitment to order.",
          "variables": [
            {
              "id": "stmContact",
              "label": "STM contact",
              "type": "text",
              "source": "specs"
            },
            {
              "id": "stmEmail",
              "label": "STM email",
              "type": "text",
              "source": "specs"
            },
            {
              "id": "deadline",
              "label": "Deadline",
              "type": "date",
              "source": "specs"
            }
          ]
        }
      ]
    }
  },
  "overrides": {
