      "title": "Scope of Supply",
      "blocks": [
        {
          "id": "b2_roof",
          "label": "Roof Waterproofing",
          "defaultOn": true,
          "text": "Complete flat roof system:\n\nMembrane: {{membrane}}\nInsulation: {{insul}}, {{insulThk}} mm\nVapour barrier: {{vapour}}\nArea: {{area}} m²\nTarget U: max {{uVal}} W/m²K\n\nInstalled as warranted assembly.\nConfirm: warranty years + conditions, fire class of build-up.",
          "variables": [
            {
              "id": "membrane",
              "label": "Membrane",
              "type": "select",
              "options": [
                "Bituminous (APP/SBS)",
                "TPO",
                "EPDM",
                "PVC",
                "Liquid applied"
              ],
              "default": "Bituminous (APP/SBS)",
              "delegateText": "Propose waterproofing suitable for roof construction.",
              "source": "specs"
            },
            {
              "id": "insul",
              "label": "Insulation",
              "type": "select",
              "options": ["PIR", "EPS", "MiWo", "XPS"],
              "default": "PIR",
              "source": "specs"
            },
            {
              "id": "insulThk",
              "label": "Insulation (mm)",
              "type": "number",
              "default": "120",
              "source": "specs"
            },
            {
              "id": "vapour",
              "label": "Vapour barrier",
              "type": "select",
              "options": ["PE foil", "Bituminous", "Aluminium", "Not required"],
              "default": "PE foil",
              "source": "specs"
            },
            {
              "id": "area",
              "label": "Area (m²)",
              "type": "number",
              "source": "specs"
            },
            {
              "id": "uVal",
              "label": "U-value",
              "type": "number",
              "default": "0.20",
              "source": "specs"
            }
          ]
        },
        {
          "id": "b2_det",
          "label": "Flashings & Details",
          "defaultOn": true,
          "text": "Include all flashings, upstands, penetrations, gutters, expansion joints. All covered by same warranty.",
          "variables": []
        },
        {
          "id": "b2_gut",
          "label": "Gutters & Downpipes",
          "defaultOn": false,
          "text": "Gutters: {{gutType}}, {{gutMat}}, {{gutLen}} m.\nDownpipes: {{downDia}} mm.\nIncludes brackets, connections, leaf guards.",
          "variables": [
            {
              "id": "gutType",
              "label": "Gutter",
              "type": "select",
              "options": ["Box (bakgoot)", "Half-round", "Concealed"],
              "default": "Box (bakgoot)",
