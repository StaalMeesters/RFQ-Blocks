            },
            {
              "id": "gutMat",
              "label": "Material",
              "type": "select",
              "options": ["Galvanised steel", "Aluminium", "Zinc", "PVC"],
              "default": "Galvanised steel",
              "source": "specs"
            },
            {
              "id": "downDia",
              "label": "Downpipe (mm)",
              "type": "number",
              "default": "100",
              "source": "specs"
            },
            {
              "id": "gutLen",
              "label": "Length (m)",
              "type": "number",
              "source": "specs"
            }
          ]
        }
      ]
    },
